<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Forced to Light (not DayNight) so the app always looks the same
         regardless of the phone's system dark-mode setting. The dashboard
         text colors are hardcoded for a light background, so following
         system dark mode made text invisible. -->
    <style name="Theme.MpesaTracker" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">#0F9D58</item>
        <item name="colorPrimaryVariant">#0B7A43</item>
        <item name="android:windowBackground">#FFFFFF</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="Theme.MpesaTracker.Dialog" parent="Theme.Material3.Light.Dialog">
        <item name="android:windowIsFloating">true</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>
</resources>
